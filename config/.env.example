# Copy to .env locally and fill in values as needed.
# ingest_crypto_documents
ONYX_BASE_URL=
ONYX_API_KEY=
ONYX_CC_PAIR_ID=3
SCAN_DIR=
STATE_FILE=
LOCK_FILE=
LOG_DIR=/volume1/Temp/logs
MAX_FILES_PER_RUN=3
REQUEST_TIMEOUT=300

# sync_media_library
SOURCE_DIR=
DEST_DIR=
MEDIA_EXTENSIONS=mpg,avi,mp4,mkv
FFMPEG_THREADS=1

# organize_temp_media
TEMP_DIR=
LOCK_FILE=/tmp/organize_temp_media.lock
LOG_DIR=/volume1/Temp/logs
REORGANIZE_EXISTING=0
FILE_EXTENSIONS=arw,ARW,mov,MOV,mp4,MP4,jpg,JPG,jpeg,JPEG,png,PNG,avi,AVI,gif,GIF,bmp,BMP,heic,HEIC,3gp,3GP
RAW_EXTENSIONS=arw,ARW
VIDEO_EXTENSIONS=mov,MOV,mp4,MP4,avi,AVI,3gp,3GP
OWNER_USER=nobody
OWNER_GROUP=users
