# Copy to `config/ingest_crypto_documents.env` locally and fill in values as needed.
# ingest_crypto_documents
FLOWRAG_BASE_URL=http://10.10.10.10:18080
FLOWRAG_API_KEY=
FLOWRAG_DATASET_ID=
SCAN_DIR=/volume1/RAG/crypto
INGESTED_DIR=/volume1/RAG/crypto/ingested
STATE_FILE=/volume1/RAG/crypto/.flowrag_ingest_state.json
LOCK_FILE=/tmp/ingest_crypto_documents.lock
LOG_DIR=/volume1/Temp/logs
MAX_FILES_PER_RUN=3
REQUEST_TIMEOUT=300
